#!/usr/bin/env bash
# gstack uninstall — removes skill symlinks from ~/.claude/skills and ~/.agents/skills
set -e

GSTACK_DIR="$(cd "$(dirname "$0")" && pwd)"
REMOVED=0

remove_gstack_links() {
  local skills_dir="$1"
  [ -d "$skills_dir" ] || return 0
  echo "Checking $skills_dir..."
  # Remove per-skill symlinks pointing to gstack/<skill>
  for link in "$skills_dir"/*/; do
    link="${link%/}"
    [ -L "$link" ] || continue
    target="$(readlink "$link")"
    case "$target" in
      gstack/*|"$GSTACK_DIR"*)
        rm -f "$link"
        echo "  removed: $link"
        REMOVED=1
        ;;
    esac
  done
  # Remove the gstack directory symlink itself
  if [ -L "$skills_dir/gstack" ]; then
    rm -f "$skills_dir/gstack"
    echo "  removed: $skills_dir/gstack"
    REMOVED=1
  fi
}

echo
echo "Uninstalling gstack..."
echo

remove_gstack_links "$HOME/.claude/skills"
remove_gstack_links "$HOME/.agents/skills"

echo
if [ "$REMOVED" -eq 0 ]; then
  echo "Nothing to uninstall — gstack does not appear to be installed."
else
  echo "gstack uninstalled."
  echo "  ~/.gstack/ data kept (project state, eval history)."
fi
