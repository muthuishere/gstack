#!/usr/bin/env bash
# gstack uninstall — removes skill symlinks from ~/.claude/skills and ~/.agents/skills
set -e

GSTACK_DIR="$(cd "$(dirname "$0")" && pwd)"
REMOVED=0

remove_gstack_links() {
  local skills_dir="$1"
  [ -d "$skills_dir" ] || return 0
  echo "Checking $skills_dir..."
  for link in "$skills_dir"/*/; do
    link="${link%/}"
    [ -L "$link" ] || continue
    target="$(readlink "$link")"
    case "$target" in
      gstack/*|"$GSTACK_DIR"*)
        rm -f "$link"
        echo "  removed: $link"
        REMOVED=1
        ;;
    esac
  done
}

echo
echo "Uninstalling gstack..."
echo

remove_gstack_links "$HOME/.claude/skills"
remove_gstack_links "$HOME/.agents/skills"

# ── ~/.gstack data directory ─────────────────────────────────────────────
if [ -d "$HOME/.gstack" ]; then
  echo
  printf "Remove ~/.gstack data directory (eval history, project state)? [y/N] "
  read -r answer </dev/tty
  case "$answer" in
    [Yy]*)
      rm -rf "$HOME/.gstack"
      echo "  removed: $HOME/.gstack"
      REMOVED=1
      ;;
    *)
      echo "  kept: $HOME/.gstack"
      ;;
  esac
fi

echo
if [ "$REMOVED" -eq 0 ]; then
  echo "Nothing to uninstall — gstack does not appear to be installed."
else
  echo "gstack uninstalled."
fi
